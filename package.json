{
  "name": "claude-code-desktop",
  "private": true,
  "version": "0.2.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:1420 && NODE_ENV=development electron .\"",
    "build": "tsc --noEmit && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "npm run build && electron-builder",
    "pack": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "better-sqlite3": "^11.0.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "highlight.js": "^11.11.1",
    "material-symbols": "^0.42.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "playwright": "^1.58.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.ccdesk.app",
    "productName": "CCDesk",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3/prebuilds/**/*",
        "to": "prebuilds"
      }
    ],
    "directories": {
      "output": "release"
    },
    "publish": null
  },
  "author": {
    "name": "liuh82",
    "email": "lkb83@163.com"
  },
  "description": "CCDesk — AI Agent chat desktop client"
}
